{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.satsangseva.net" }],
      "destination": "https://satsangseva.net/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
