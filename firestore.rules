rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers -----------------------------------------------------------

    // The signed-in user's phone number in normalized international form
    // (e.g. "61404876234"). Matches normalizePhone() in src/utils/contacts.js.
    // Returns a sentinel when missing so it can never accidentally match a
    // real guest grant.
    function myPhone() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.get('mobileNormalized', '__none__');
    }

    // True when the signed-in user holds an app-account invite to this satsang.
    // Invitations use a deterministic id of "<satsangId>_<toUid>" so a single
    // exists() check works (no querying inside rules).
    function isInvited(satsangId) {
      return exists(/databases/$(database)/documents/invitations/$(satsangId + '_' + request.auth.uid));
    }

    // True when the signed-in user was invited by phone number (guest docs use
    // a deterministic id of "<satsangId>_<normalizedPhone>").
    function isPhoneGuest(satsangId) {
      return exists(/databases/$(database)/documents/guests/$(satsangId + '_' + myPhone()));
    }

    // Admins get read-only visibility across all collections for the admin
    // dashboard. UID-based (the uid comes from the auth token and can't be
    // spoofed). Keep this list in sync with ADMIN_UIDS in src/config/admins.js.
    function isAdmin() {
      return request.auth != null
        && request.auth.uid in [
          'QRyzzGcLqWZMvsi2KlTPqohCASM2',  // shri.shishirendu@gmail.com
          'dc4xSXwmYAhmCS6pAGCTqwUJlR72'   // poojamohitjain07@gmail.com (Mohit Jain)
        ];
    }

    // True when the user may forward/add others to a satsang. For a PRIVATE
    // satsang only the host may invite — an invitee cannot pass access on. A
    // PUBLIC satsang may be forwarded by anyone who can see it.
    function canForward(satsangId) {
      let s = get(/databases/$(database)/documents/satsangs/$(satsangId)).data;
      return s.publicInvite == true
        || request.auth.uid == s.hostUid;
    }

    // ---- Collections -------------------------------------------------------

    // Users — any signed-in user can read profiles (needed to pick sangat);
    // each user owns their own document.
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    // Satsangs. A satsang's document id is an unguessable random key, so the
    // invite link is itself a capability: anyone signed in who HAS the link may
    // open that ONE satsang. This is what lets a WhatsApp-shared private invite
    // actually open for whoever receives it.
    //
    // "get" (a single doc by id — the shared link) is open to any signed-in user.
    // "list" (querying/enumerating the collection) stays locked down so private
    // satsangs can't be trawled: a query only succeeds if every doc it returns is
    // public, hosted by, or granted to the caller. This mirrors exactly what
    // loadVisibleSatsangs() queries, so the calendar keeps working while private
    // events stay off everyone else's calendar (reachable only via their link).
    match /satsangs/{satsangId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null && (
        resource.data.publicInvite == true ||
        request.auth.uid == resource.data.hostUid ||
        isInvited(satsangId) ||
        isPhoneGuest(satsangId) ||
        isAdmin()
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.hostUid;
      allow update, delete: if request.auth.uid == resource.data.hostUid;
    }

    // RSVPs — readable only by the responder themselves or the satsang host.
    // Anyone who can see the satsang may submit their own RSVP.
    match /rsvps/{rsvpId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.auth.uid == get(/databases/$(database)/documents/satsangs/$(resource.data.inviteId)).data.hostUid ||
        isAdmin()
      );
      // Anyone signed in may submit their OWN rsvp. Viewing a satsang is open to
      // whoever holds the link, so responding to it is too.
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth.uid == resource.data.uid;
    }

    // Invitations — the app-account grant. Deterministic id "<inviteId>_<toUid>".
    // Sender or recipient can read; only the host or someone already invited may
    // create one (this is what makes forwarding work without leaking access).
    match /invitations/{invId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.fromUid ||
         request.auth.uid == resource.data.toUid ||
         isAdmin());
      allow create: if request.auth != null
        && invId == request.resource.data.inviteId + '_' + request.resource.data.toUid
        && request.auth.uid == request.resource.data.fromUid
        && canForward(request.resource.data.inviteId);
      allow delete: if request.auth != null && request.auth.uid == resource.data.fromUid;
    }

    // Guests — the phone-number grant. Deterministic id "<inviteId>_<phone>".
    // Readable by the host or whoever added the guest; creatable by the host or
    // anyone already invited (forwarding to a phone contact).
    match /guests/{guestId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.addedByUid ||
        request.auth.uid == get(/databases/$(database)/documents/satsangs/$(resource.data.inviteId)).data.hostUid ||
        // The invited guest themselves, once registered: their normalized number
        // matches the grant, so they can list their own phone invites (needed to
        // surface them on the calendar, not just via the direct link).
        resource.data.phone == myPhone() ||
        isAdmin()
      );
      allow create: if request.auth != null
        && guestId == request.resource.data.inviteId + '_' + request.resource.data.phone
        && request.auth.uid == request.resource.data.addedByUid
        && (
          // The host (or anyone, for a public satsang) inviting others.
          canForward(request.resource.data.inviteId) ||
          // Self-record: on opening a shared link a viewer records their OWN
          // number so the host can see who opened and it shows on their calendar.
          // Limited to their own number, so it can't grant access to anyone else.
          request.resource.data.phone == myPhone()
        );
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.addedByUid;
    }
  }
}
