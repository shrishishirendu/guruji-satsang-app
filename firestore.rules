rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — can read own profile, create once, update own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
    }

    // Satsangs — any auth user can read; only creator can update/delete
    match /satsangs/{satsangId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.hostUid;
    }

    // RSVPs — any auth user can create; only own RSVP readable/editable
    match /rsvps/{rsvpId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.uid;
    }

    // Invitations — sender or recipient can read
    match /invitations/{invId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.fromUid ||
         request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null;
    }

    // Guests — phone-directory invitees added by a host.
    // Any auth user can read (host views them on the RSVP list); only the
    // host who added a guest can modify or remove them.
    match /guests/{guestId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.addedByUid;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.addedByUid;
    }
  }
}
